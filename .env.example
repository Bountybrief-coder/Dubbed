# Supabase project credentials — copy this file to `.env` and fill in.
# Find these in your Supabase dashboard: Project Settings > API.
# These are the ONLY env vars needed for the client build (Vite inlines them).

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Server-side only (Supabase Edge Function secrets) ---
# Do NOT put these in .env or commit them. Set them via:
#   supabase secrets set KEY=value
#
# NOWPAYMENTS_API_KEY=your-nowpayments-api-key
# NOWPAYMENTS_IPN_SECRET=your-ipn-secret-from-nowpayments-dashboard
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_ANON_KEY=eyJ...
#
# See docs/DASHBOARD_STEPS.md for the full setup checklist.
